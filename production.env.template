# VARTAPRAVAH Production Environment Template
# Copy this to .env and fill in with your production values

# ============================================================
# STREAMING CONFIGURATION
# ============================================================

# YouTube Live Stream RTMP URL with your stream key
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2/XXXX-XXXX-XXXX-XXXX-XXXX

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_SECURE_PASSWORD@postgres:5432/vartapravah

# Database host (use service name in docker-compose)
DB_HOST=postgres

# Database port
DB_PORT=5432

# Database name
DB_NAME=vartapravah

# Database user
DB_USER=postgres

# Database password (use strong password in production)
DB_PASS=YOUR_SECURE_PASSWORD

# ============================================================
# REDIS CONFIGURATION
# ============================================================

# Redis host (use service name in docker-compose)
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# ============================================================
# API KEYS & EXTERNAL SERVICES
# ============================================================

# Groq API Key for LLM services
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# NewsAPI Key for news fetching
# Get from: https://newsapi.org
NEWS_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google Translate API Key (optional, for Marathi translation)
# Get from: https://cloud.google.com/docs/authentication/api-keys
GOOGLE_TRANSLATE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# DOCKER BUILD CONFIGURATION
# ============================================================

# Enable Docker BuildKit for faster, better builds
DOCKER_BUILDKIT=1

# Enable BuildKit in Docker Compose
COMPOSE_DOCKER_CLI_BUILD=1

# ============================================================
# ORACLE CLOUD RELAY CONFIGURATION
# ============================================================

# Oracle Cloud instance IP address
ORACLE_IP=XXX.XXX.XXX.XXX

# SSH username for Oracle Cloud
ORACLE_USER=ubuntu

# Path to Oracle SSH private key (inside container)
ORACLE_KEY_PATH=/app/oracle_key.key

# Remote video directory on Oracle Cloud
ORACLE_VIDEO_DIR=/home/ubuntu/videos

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================

# Prevent Python from buffering stdout/stderr
PYTHONUNBUFFERED=1

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# GPU acceleration (set to True only if CUDA available)
USE_GPU=False

# Python path for imports
PYTHONPATH=/app:/app/app

# ============================================================
# DOMAIN & SSL CONFIGURATION
# ============================================================

# Your production domain
DOMAIN=your-domain.com

# Frontend URL (for CORS if needed)
FRONTEND_URL=https://your-domain.com

# API Base URL
API_URL=https://your-domain.com/api

# ============================================================
# PERFORMANCE TUNING
# ============================================================

# Worker threads for FastAPI
UVICORN_WORKERS=4

# Max connections to PostgreSQL
DB_POOL_SIZE=20

# Max overflow connections
DB_POOL_MAX_OVERFLOW=10

# Connection pool recycle time (seconds)
DB_POOL_RECYCLE=3600

# ============================================================
# SECURITY
# ============================================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Secret key for JWT tokens (generate a strong random string)
SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# MONITORING & ALERTS
# ============================================================

# Enable error tracking (if using Sentry)
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Email for alerts
ALERT_EMAIL=ops@your-domain.com

# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# ============================================================
# BACKUP & RETENTION
# ============================================================

# Backup retention days
BACKUP_RETENTION_DAYS=30

# Backup location
BACKUP_DIR=/backups

# ============================================================
# TIMEZONE
# ============================================================

# Set timezone for application (e.g., Asia/Kolkata for India)
TZ=Asia/Kolkata

# ============================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================

# Environment type: production, staging, development
ENVIRONMENT=production

# Application version
APP_VERSION=1.0.0

# ============================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================

# 1. NEVER commit this file with real values to git
# 2. Keep backups of this file in secure location
# 3. Change all default passwords and API keys
# 4. Use strong, randomly generated passwords (min 32 chars)
# 5. Rotate API keys periodically (at least quarterly)
# 6. Monitor .env file changes
# 7. Use secret management tools for sensitive values
# 8. Ensure file permissions are restricted: chmod 600 .env

